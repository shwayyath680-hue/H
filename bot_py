# استقبال الصور وحفظها
user_photos = {}

@bot.message_handler(content_types=['photo'])
def handle_photos(message):
    chat_id = message.chat.id
    file_info = bot.get_file(message.photo[-1].file_id)
    downloaded_file = bot.download_file(file_info.file_path)
    
    # حفظ الصورة باسم مؤقت
    file_name = f"img_{chat_id}_{message.message_id}.jpg"
    with open(file_name, 'wb') as new_file:
        new_file.write(downloaded_file)
    
    if chat_id not in user_photos:
        user_photos[chat_id] = []
    user_photos[chat_id].append(file_name)
    
    bot.reply_to(message, f"✅ تم استلام الصورة رقم {len(user_photos[chat_id])}")

# معالجة الصور وتحويلها لـ PDF عند إرسال كلمة "تم"
@bot.message_handler(func=lambda m: m.text == "تم")
def convert_to_pdf(message):
    chat_id = message.chat.id
    if chat_id not in user_photos or not user_photos[chat_id]:
        bot.send_message(chat_id, "أرسل بعض الصور أولاً!")
        return

    bot.send_message(chat_id, "⏳ جاري إنشاء ملف الـ PDF... انتظر لحظة.")
    
    try:
        pdf_path = f"notes_{chat_id}.pdf"
        images_list = [Image.open(img).convert('RGB') for img in user_photos[chat_id]]
        
        images_list[0].save(pdf_path, save_all=True, append_images=images_list[1:])
        
        with open(pdf_path, 'rb') as pdf:
            bot.send_document(chat_id, pdf, caption="📄 تفضل، هذا ملفك جاهز!")
            
        for img in user_photos[chat_id]:
            os.remove(img)
        os.remove(pdf_path)
        user_photos[chat_id] = []
        
    except Exception as e:
        bot.send_message(chat_id, f"حدث خطأ أثناء المعالجة: {e}")

